# Terraform
.terraform/
terraform.tfstate
terraform.tfstate.backup
*.tfplan

# Terraform local secrets / vars (do not commit)
terraform/terraform.tfvars
terraform/*.tfvars
terraform/*.tfvars.local
terraform.tfvars
terraform.tfvars.local

# AWS installer / trust doc
AWSCLIV2.pkg
trust.json

# AGRO-AI generated artifacts
agroai/agroai_results.csv
agroai/charts/*.png
agroai/reports/*.html

# OS
.DS_Store

# Python
__pycache__/
*.pyc

# Ignore accidental root init if needed
__init__.py


# allow non-sensitive CI vars
!terraform.auto.tfvars
