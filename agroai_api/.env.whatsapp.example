# AGRO-AI WhatsApp Field Intelligence — official Meta Cloud API only.
# Copy these names into BOTH the API service and Field Intelligence worker.
# Never commit real values. Never expose them through Vite/browser variables.

# Keep false until migration 028 is applied and API/worker exact-SHA alignment is verified.
WHATSAPP_ENABLED=false

# Generate a high-entropy random token. Enter the same value when Meta verifies
# https://api.agroai-pilot.com/v1/whatsapp/webhook
WHATSAPP_VERIFY_TOKEN=

# Meta App Dashboard > App settings > Basic > App secret.
# Used exclusively to verify X-Hub-Signature-256 before JSON parsing.
WHATSAPP_APP_SECRET=

# Pin a Meta Graph API version that is currently supported for the business app.
# AGRO-AI intentionally has no guessed application default.
WHATSAPP_GRAPH_API_VERSION=
WHATSAPP_GRAPH_API_BASE_URL=https://graph.facebook.com

# Defensive transport limits.
WHATSAPP_WEBHOOK_MAX_BYTES=2097152
WHATSAPP_MEDIA_MAX_BYTES=52428800
WHATSAPP_HTTP_TIMEOUT_SECONDS=20
WHATSAPP_SERVICE_WINDOW_HOURS=24
WHATSAPP_MAX_ATTEMPTS=5

# Existing AGRO-AI dependencies required by the channel.
# Use a versioned explicit keyring in production when possible.
CONNECTOR_CREDENTIAL_MASTER_KEY=
CONNECTOR_CREDENTIAL_ACTIVE_KEY_VERSION=v1
CONNECTOR_CREDENTIAL_KEYS_JSON=

CONNECTOR_OBJECT_STORAGE_BACKEND=r2
CONNECTOR_OBJECT_BUCKET=
CONNECTOR_OBJECT_PREFIX=agroai/field-intelligence
CONNECTOR_OBJECT_ENDPOINT_URL=
CLOUDFLARE_R2_ACCESS_KEY_ID=
CLOUDFLARE_R2_SECRET_ACCESS_KEY=

FIELD_INTELLIGENCE_RELEASE_STATE=internal
FIELD_INTELLIGENCE_WORKER_ENABLED=true
FIELD_WORKER_INTERVAL_SECONDS=15
FIELD_WORKER_BATCH=25
