# AGRO-AI dedicated demo backend template
# Copy values into the DEMO backend service secret store. Do not commit real values.

APP_ENV=demo
APP_URL=https://demo.agroai-pilot.com
API_URL=https://demo-api.agroai-pilot.com

# REQUIRED: dedicated demo database. Never point the demo service at production.
DATABASE_URL=postgresql://demo-user:replace-me@demo-db-host:5432/agroai_demo

# Independent demo runtime secrets. Do not reuse production signing keys.
SECRET_KEY=
WEBHOOK_SECRET=
OAUTH_STATE_SIGNING_KEY=
CONNECTOR_CREDENTIAL_MASTER_KEY=
NON_CUSTOMER_ACCESS_PROVISIONING_TOKEN=

# Idempotent startup seed. Runs only because APP_ENV=demo too.
DEMO_AUTO_PROVISION=true
DEMO_FULL_EMAIL=
DEMO_FULL_PASSWORD=
DEMO_FREE_EMAIL=
DEMO_FREE_PASSWORD=
DEMO_FULL_ORGANIZATION_NAME=AGRO-AI Demo Organization
DEMO_FREE_ORGANIZATION_NAME=AGRO-AI Free Demo

# Optional explicit allowlist. The seeded full demo identity is already provisioned,
# but listing it here allows safe self-repair after revocation/recreation.
DEMO_FULL_ACCESS_EMAILS=

# Founder/internal production-style bypass can be tested here too, but keep the
# list server-side and explicit. Never expose it to the frontend.
INTERNAL_FULL_ACCESS_EMAILS=

# Demo runtime should not own production billing.
# Leave empty unless intentionally using Stripe TEST MODE credentials/prices.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_PRO_MONTHLY=
STRIPE_PRICE_PRO_ANNUAL=
STRIPE_PRICE_TEAM_MONTHLY=
STRIPE_PRICE_TEAM_ANNUAL=
STRIPE_PRICE_NETWORK_MONTHLY=
STRIPE_PRICE_NETWORK_ANNUAL=

# Use demo/sandbox provider credentials only. Never copy customer production secrets.
WISECONN_API_KEY=
TALGIL_API_KEY=
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
MICROSOFT_OAUTH_CLIENT_ID=
MICROSOFT_OAUTH_CLIENT_SECRET=
DROPBOX_OAUTH_CLIENT_ID=
DROPBOX_OAUTH_CLIENT_SECRET=
BOX_OAUTH_CLIENT_ID=
SLACK_OAUTH_CLIENT_ID=
SALESFORCE_OAUTH_CLIENT_ID=
JOHN_DEERE_OAUTH_CLIENT_ID=
JOHN_DEERE_OAUTH_CLIENT_SECRET=

# AI can use a separately budgeted demo key. Keep it server-side.
AI_PROVIDER=
AI_BASE_URL=
AI_API_KEY=
AI_MODEL=
AI_FAST_MODEL=
AI_REASONING_MODEL=
AI_REPORT_MODEL=

# Demo scheduler off by default; enable only with sandbox/demo data sources.
ENABLE_SCHEDULER=false
ENABLE_METERING=true
