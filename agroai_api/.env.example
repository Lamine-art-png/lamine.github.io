# Database
# Local dev with Docker:
DATABASE_URL=postgresql://agroai:agroai@localhost:5432/agroai
# Local dev without Docker:
# DATABASE_URL=sqlite:///./agroai.db
# Production (Neon free tier — get yours at https://neon.tech):
# DATABASE_URL=postgresql://user:pass@ep-xxx.us-east-2.aws.neon.tech/agroai?sslmode=require

# Security
SECRET_KEY=your-secret-key-min-32-chars-change-in-production
WEBHOOK_SECRET=your-webhook-secret-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Observability
LOG_LEVEL=INFO
ENABLE_METRICS=true

# Caching
CACHE_TTL_HOURS=6
IDEMPOTENCY_TTL_HOURS=24

# Feature Flags
ENABLE_WEBHOOKS=true
ENABLE_METERING=true

# Scheduler
ENABLE_SCHEDULER=true
SYNC_INTERVAL_MINUTES=15         # How often to sync WiseConn data
SYNC_LOOKBACK_DAYS=14            # Days of history to sync each run

# External Providers
WISECONN_API_URL=https://api.wiseconn.com
WISECONN_API_KEY=              # API key from WiseConn (never commit the real value)
WISECONN_TIMEOUT_SECONDS=30
WISECONN_MAX_RETRIES=3
RAINBIRD_API_URL=http://mock-rainbird
OPENET_API_URL=http://mock-openet
