# Database
DATABASE_URL=postgresql://agroai:agroai@localhost:5432/agroai
# Local fallback only: DATABASE_URL=sqlite:///./agroai.db

# Security
SECRET_KEY=replace-with-a-long-random-value
WEBHOOK_SECRET=replace-with-a-long-random-value
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Observability
LOG_LEVEL=INFO
ENABLE_METRICS=true

# Caching
CACHE_TTL_HOURS=6
IDEMPOTENCY_TTL_HOURS=24

# Feature flags
ENABLE_WEBHOOKS=true
ENABLE_METERING=true

# SaaS app + Stripe commercial billing
APP_ENV=development
APP_URL=https://app.agroai-pilot.com
API_URL=https://api.agroai-pilot.com
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_PRO_MONTHLY=
STRIPE_PRICE_PRO_ANNUAL=
STRIPE_PRICE_TEAM_MONTHLY=
STRIPE_PRICE_TEAM_ANNUAL=
STRIPE_PRICE_NETWORK_MONTHLY=
STRIPE_PRICE_NETWORK_ANNUAL=
# Optional one-time assurance service prices. These do not grant SaaS plans.
STRIPE_PRICE_ASSURANCE_AUDIT_FARM=
STRIPE_PRICE_ASSURANCE_AUDIT_NETWORK=

# Server-authoritative AGRO-AI internal/demo access profiles.
# Comma-separated VERIFIED account emails. Keep these server-side only.
INTERNAL_FULL_ACCESS_EMAILS=
DEMO_FULL_ACCESS_EMAILS=
# Separate least-privilege allowlist for the global customer directory and CSV export.
PLATFORM_ADMIN_EMAILS=
# High-entropy secret for explicit provisioning/revocation endpoints. Never expose to Vite/browser env.
NON_CUSTOMER_ACCESS_PROVISIONING_TOKEN=

# Dedicated demo environment only. Use a separate demo DB and separate demo hostnames.
# Startup self-seeding runs only when APP_ENV=demo AND DEMO_AUTO_PROVISION=true.
DEMO_AUTO_PROVISION=false
DEMO_FULL_EMAIL=
DEMO_FULL_PASSWORD=
DEMO_FREE_EMAIL=
DEMO_FREE_PASSWORD=
DEMO_FULL_ORGANIZATION_NAME=AGRO-AI Demo Organization
DEMO_FREE_ORGANIZATION_NAME=AGRO-AI Free Demo

# The web process must not own distributed scheduled work.
ENABLE_SCHEDULER=false
SYNC_INTERVAL_MINUTES=15
SYNC_LOOKBACK_DAYS=14

# External providers
WISECONN_API_URL=https://api.wiseconn.com
WISECONN_API_KEY=
WISECONN_TIMEOUT_SECONDS=30
WISECONN_MAX_RETRIES=3
RAINBIRD_API_URL=http://mock-rainbird
OPENET_API_URL=http://mock-openet

# AI gateway / hybrid model plane
# Existing always-on Cloudflare Workers AI edge origin.
AI_PROVIDER=ollama
AI_BASE_URL=https://local-ai.agroai-pilot.com
AI_EDGE_BASE_URL=https://local-ai.agroai-pilot.com
AI_EDGE_MODEL=@cf/zai-org/glm-4.7-flash
# Match this value to the Worker secret ORIGIN_TOKEN before enforcing origin auth.
AI_EDGE_AUTH_TOKEN=
AI_EDGE_TIMEOUT_SECONDS=45

# Actual Mac-hosted Ollama lane. Keep this distinct from the Workers AI edge origin.
# For a public Cloudflare Tunnel hostname, protect it with Access Service Auth and set both credentials.
AI_LOCAL_BASE_URL=
AI_LOCAL_MODEL=qwen3.5:4b
AI_LOCAL_CF_ACCESS_CLIENT_ID=
AI_LOCAL_CF_ACCESS_CLIENT_SECRET=
AI_LOCAL_NUM_CTX=6144
AI_LOCAL_MAX_TOKENS=1200
AI_LOCAL_TIMEOUT_SECONDS=90
AI_LOCAL_THINKING=false

# Hosted frontier / challenger lane.
# Keep provider secrets out of source control.
OPENROUTER_API_KEY=
AI_API_KEY=
AI_MODEL=
AI_REASONING_MODEL=z-ai/glm-5.2
AI_REPORT_MODEL=z-ai/glm-5.2
AI_FAST_MODEL=qwen/qwen3.5-flash-02-23
AI_CHALLENGER_MODEL=deepseek/deepseek-v4-pro
# Optional and volatile: only set after revalidating current free-route availability.
AI_FREE_MODEL=
AI_MODEL_FALLBACKS=z-ai/glm-5.2,deepseek/deepseek-v4-pro,qwen/qwen3.5-flash-02-23,z-ai/glm-5-turbo,z-ai/glm-4.5-air
AI_ROUTING_MODE=hybrid
AI_MODEL_TEST_COMMANDS_ENABLED=false
AI_TIMEOUT_SECONDS=60

# One-time OAuth state
OAUTH_STATE_SIGNING_KEY=
OAUTH_STATE_TTL_SECONDS=900

# Connector credential vault
# URL-safe base64 encoding of exactly 32 random bytes.
CONNECTOR_CREDENTIAL_MASTER_KEY=
CONNECTOR_CREDENTIAL_ACTIVE_KEY_VERSION=v1
# Optional rotation keyring: {"v1":"...","v2":"..."}
CONNECTOR_CREDENTIAL_KEYS_JSON=

# Durable Cloudflare R2 connector objects
CONNECTOR_OBJECT_STORAGE_BACKEND=r2
CONNECTOR_OBJECT_BUCKET=
CONNECTOR_OBJECT_PREFIX=agroai
CONNECTOR_OBJECT_REGION=auto
# https://<account-id>.r2.cloudflarestorage.com
CONNECTOR_OBJECT_ENDPOINT_URL=
CLOUDFLARE_R2_ACCESS_KEY_ID=
CLOUDFLARE_R2_SECRET_ACCESS_KEY=

# Durable connector task plane
# Production target: Cloudflare Queues through the edge gateway.
TASK_QUEUE_BACKEND=cloudflare_queues
CLOUDFLARE_QUEUE_PUBLISH_URL=https://api.agroai-pilot.com/v1/internal/edge/connector-tasks
CLOUDFLARE_QUEUE_PUBLISH_TOKEN=
CLOUDFLARE_QUEUE_CONSUMER_TOKEN=
TASK_QUEUE_MAX_ATTEMPTS=5
TASK_QUEUE_RETRY_BASE_SECONDS=15

# Optional compatibility transport for local integration testing only.
# TASK_QUEUE_BACKEND=redis_streams
REDIS_URL=
TASK_QUEUE_STREAM=agroai:tasks
TASK_QUEUE_GROUP=agroai-workers
TASK_QUEUE_BLOCK_MS=5000
TASK_QUEUE_LEASE_SECONDS=120

# OAuth provider configuration
DROPBOX_OAUTH_CLIENT_ID=
DROPBOX_OAUTH_CLIENT_SECRET=
DROPBOX_OAUTH_REDIRECT_URI=
BOX_OAUTH_CLIENT_ID=
SLACK_OAUTH_CLIENT_ID=
SALESFORCE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=
MICROSOFT_OAUTH_CLIENT_ID=
MICROSOFT_OAUTH_CLIENT_SECRET=
MICROSOFT_OAUTH_REDIRECT_URI=

# John Deere Operations Center OAuth + read-only API
JOHN_DEERE_OAUTH_CLIENT_ID=
JOHN_DEERE_OAUTH_CLIENT_SECRET=
JOHN_DEERE_OAUTH_REDIRECT_URI=https://api.agroai-pilot.com/v1/connectors/oauth/callback
JOHN_DEERE_OAUTH_AUTHORIZE_URL=https://signin.johndeere.com/oauth2/aus78tnlaysMraFhC1t7/v1/authorize
JOHN_DEERE_OAUTH_TOKEN_URL=https://signin.johndeere.com/oauth2/aus78tnlaysMraFhC1t7/v1/token
JOHN_DEERE_OAUTH_SCOPES=ag1 ag2 ag3 eq1 eq2 org1 org2 offline_access
JOHN_DEERE_API_BASE_URL=https://api.deere.com/platform

# Optional decision freshness override (seconds by evidence type)
INTELLIGENCE_FRESHNESS_POLICY_JSON=

# Platform API private enterprise partner beta
PLATFORM_API_ENABLED=false
PLATFORM_API_DEVELOPER_CONTROL_PLANE_ENABLED=false
PLATFORM_API_TEST_PROJECTS_ENABLED=false
PLATFORM_API_LIVE_PROJECTS_ENABLED=false
PLATFORM_API_WEBHOOK_DELIVERY_ENABLED=false
PLATFORM_API_PUBLIC_DOCS_ENABLED=false
PLATFORM_API_USAGE_METERING_ENFORCEMENT_ENABLED=false
PLATFORM_API_MARKETING_ENABLED=false
PLATFORM_API_APPLICATIONS_ENABLED=false
PLATFORM_API_PRIVATE_BETA_ENABLED=false
PLATFORM_API_PARTNER_PROGRAM_ENABLED=false
PLATFORM_API_SELF_SERVICE_SANDBOX_ENABLED=false
PLATFORM_API_LIVE_ACCESS_REQUESTS_ENABLED=false
PLATFORM_API_BILLING_ENABLED=false
PLATFORM_API_STRIPE_CHECKOUT_ENABLED=false
PLATFORM_API_STRIPE_METER_EXPORT_ENABLED=false
PLATFORM_API_PRICING_ENABLED=false
PLATFORM_API_SDK_DOWNLOADS_ENABLED=false
PLATFORM_API_STATUS_PAGE_ENABLED=false
PLATFORM_API_SUPPORT_ENABLED=false
PLATFORM_API_TERMS_ENFORCEMENT_ENABLED=false
PLATFORM_API_INTERNAL_TEST_ORG_ID=
# Required in production. Do not commit the real value.
PLATFORM_API_KEY_PEPPER=
# Production target: redis. The memory backend is test/development only.
PLATFORM_API_RATE_LIMIT_BACKEND=redis
PLATFORM_API_REDIS_URL=
PLATFORM_API_RATE_LIMIT_FAIL_OPEN=false
PLATFORM_API_REDIS_MAX_RETRIES=1
PLATFORM_API_REDIS_CONNECT_TIMEOUT_SECONDS=2
PLATFORM_API_REDIS_SOCKET_TIMEOUT_SECONDS=2
PLATFORM_API_TEST_BURST_LIMIT=60
PLATFORM_API_TEST_SUSTAINED_LIMIT=600
PLATFORM_API_LIVE_BURST_LIMIT=600
PLATFORM_API_LIVE_SUSTAINED_LIMIT=6000
PLATFORM_API_IDEMPOTENCY_TTL_HOURS=24
PLATFORM_API_EDGE_AUTH_SECRET=
PLATFORM_API_WEBHOOK_SECRET_KEYS_JSON=
PLATFORM_API_WEBHOOK_SECRET_ACTIVE_KEY_VERSION=v1
PLATFORM_API_WEBHOOK_ALLOWED_PORTS=443
PLATFORM_API_WEBHOOK_TIMEOUT_SECONDS=10
PLATFORM_API_WEBHOOK_MAX_RESPONSE_BYTES=8192
PLATFORM_API_WEBHOOK_MAX_ATTEMPTS=6
PLATFORM_API_WEBHOOK_SECRET_OVERLAP_MINUTES=60
PLATFORM_API_APPLICATION_LIMIT_PER_DAY=3
PLATFORM_API_PLAN_CATALOG_VERSION=2026-07-provisional
PLATFORM_API_OPERATION_COST_CATALOG_VERSION=2026-07-provisional
PLATFORM_API_STRIPE_SECRET_KEY=
PLATFORM_API_STRIPE_WEBHOOK_SECRET=
PLATFORM_API_STRIPE_METER_EVENT_NAME=
PLATFORM_API_STRIPE_METER_ID=
PLATFORM_API_STRIPE_CUSTOMER_PORTAL_CONFIGURATION=
PLATFORM_API_STRIPE_TAX_ENABLED=false
PLATFORM_API_STRIPE_SANDBOX_PRODUCT_ID=
PLATFORM_API_STRIPE_DEVELOPER_MONTHLY_PRICE_ID=
PLATFORM_API_STRIPE_DEVELOPER_ANNUAL_PRICE_ID=
PLATFORM_API_STRIPE_DEVELOPER_OVERAGE_PRICE_ID=
PLATFORM_API_STRIPE_SCALE_MONTHLY_PRICE_ID=
PLATFORM_API_STRIPE_SCALE_ANNUAL_PRICE_ID=
PLATFORM_API_STRIPE_SCALE_OVERAGE_PRICE_ID=
PLATFORM_API_BILLING_GRACE_DAYS=7
PLATFORM_API_USAGE_NOTIFICATION_THRESHOLDS=50,80,100
PLATFORM_API_KEY_EXPIRY_NOTIFICATION_DAYS=7
PLATFORM_API_METER_EXPORT_MAX_ATTEMPTS=8
PLATFORM_API_REQUEST_LOG_MAX_PAGE_SIZE=100
PLATFORM_API_SUPPORT_MAX_ATTACHMENT_BYTES=10485760
PLATFORM_API_LIVE_AUTO_APPROVAL_ENABLED=false
EARTHDAILY_ADAPTER_ENABLED=false
VALLEY_IRRIGATION_ADAPTER_ENABLED=false
VALLEY_IRRIGATION_WRITE_CAPABILITY_ENABLED=false
# Comma-separated HTTPS provider hosts approved for server-side calls.
PROVIDER_BASE_URL_ALLOWLIST=
