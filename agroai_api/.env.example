# Database
# Local dev with Docker:
DATABASE_URL=postgresql://agroai:agroai@localhost:5432/agroai
# Local dev without Docker:
# DATABASE_URL=sqlite:///./agroai.db
# Production (Neon free tier — get yours at https://neon.tech):
# DATABASE_URL=postgresql://user:pass@ep-xxx.us-east-2.aws.neon.tech/agroai?sslmode=require

# Security
SECRET_KEY=your-secret-key-min-32-chars-change-in-production
WEBHOOK_SECRET=your-webhook-secret-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Observability
LOG_LEVEL=INFO
ENABLE_METRICS=true

# Caching
CACHE_TTL_HOURS=6
IDEMPOTENCY_TTL_HOURS=24

# Feature Flags
ENABLE_WEBHOOKS=true
ENABLE_METERING=true

# Scheduler
ENABLE_SCHEDULER=true
SYNC_INTERVAL_MINUTES=15         # How often to sync WiseConn data
SYNC_LOOKBACK_DAYS=14            # Days of history to sync each run

# External Providers
WISECONN_API_URL=https://api.wiseconn.com
WISECONN_API_KEY=              # API key from WiseConn (never commit the real value)
WISECONN_TIMEOUT_SECONDS=30
WISECONN_MAX_RETRIES=3
RAINBIRD_API_URL=http://mock-rainbird
OPENET_API_URL=http://mock-openet

# ── FCGMA Water Intelligence Copilot ──────────────────────────────────────
# CIMIS weather context (California DWR — https://et.water.ca.gov/Rest/Index)
# Request a free key at https://et.water.ca.gov/Home/Register
# NEVER commit a real value — this file is safe because the value is blank.
CIMIS_APP_KEY=                   # your CIMIS app key (optional — graceful disabled state if absent)
CIMIS_TARGET=Cimis Station 152   # Ventura County station (configurable)

# Optional: LLM for Terris answer narration (Structured Safe mode used if absent)
# ANTHROPIC_API_KEY=             # falls back to this when TERRIS_LLM_API_KEY is not set

# Terris LLM provider (overrides ANTHROPIC_API_KEY when set)
# TERRIS_LLM_PROVIDER=anthropic  # "anthropic" (default) | "openai" | "gemini_demo" | "ollama"
# TERRIS_LLM_MODEL=claude-sonnet-4-6  # override the default model for the chosen provider
# TERRIS_LLM_API_KEY=            # provider API key — never commit a real value

# Terris Gemini Demo Intelligence (free developer tier, illustrative data only)
# Configure with: bash scripts/configure_terris_gemini_demo.sh
# TERRIS_GEMINI_API_KEY=         # Gemini free-tier key — never commit a real value
# TERRIS_GEMINI_MODEL=gemini-3.5-flash   # model override (default: gemini-3.5-flash)
# TERRIS_EXTERNAL_DEMO_ONLY=true         # restrict to illustrative/sanitized data only
# TERRIS_EXTERNAL_BLOCK_PRIVATE=true     # block private/confidential provenance (default: true)
# TERRIS_EXTERNAL_ALLOWED_PROVENANCE=public_context,sanitized_replay,injected_demo_scenario
# TERRIS_EXTERNAL_MAX_TOOL_ITERATIONS=6  # max tool-calling iterations
# TERRIS_EXTERNAL_TIMEOUT_SECONDS=120    # wall-clock timeout for Gemini calls
# TERRIS_GEMINI_HEALTH_TTL_SECONDS=120   # seconds before health state is considered stale

# Terris Ollama Local Intelligence (local inference, no cloud key required)
# Configure with: bash scripts/configure_terris_local.sh
# TERRIS_OLLAMA_BASE_URL=http://127.0.0.1:11434  # must be loopback only
# TERRIS_OLLAMA_MODEL=llama3.1:8b
# TERRIS_OLLAMA_FALLBACK_MODEL=llama3.2:3b
# TERRIS_OLLAMA_NUM_CTX=32768
# TERRIS_OLLAMA_MAX_TOOL_ITERATIONS=6
# TERRIS_OLLAMA_TIMEOUT_SECONDS=180
