# Field Intelligence STAGING environment template — placeholders only.
# Real values live exclusively in the protected GitHub environment
# `field-intelligence-staging` and in the staging service provider.
# NEVER reuse production values for any of these.

# --- Staging service identity -------------------------------------------------
APP_ENV=staging
GIT_SHA=                                   # set by the staging deploy (exact commit)

# --- Staging surfaces (provider-generated URLs until DNS is provisioned) -----
FIELD_STAGING_API_URL=                     # e.g. https://agroai-api-staging.onrender.com
FIELD_STAGING_PORTAL_URL=                  # e.g. https://field-intelligence-staging.agroai-portal-staging.pages.dev
FIELD_STAGING_PORTAL_PROJECT=agroai-portal-staging
PRODUCTION_PORTAL_PROJECT=agroai-portal

# --- Staging database (isolated; NEVER the production database) --------------
FIELD_STAGING_DATABASE_URL=                # postgresql://... dedicated staging instance
PRODUCTION_DATABASE_RESOURCE_FINGERPRINT=  # host:port/database, no credentials

# --- Immutable staging deployment identities ---------------------------------
FIELD_STAGING_DEPLOY_PROVIDER=render
FIELD_STAGING_API_SERVICE_ID=              # immutable staging API service id
FIELD_STAGING_DEPLOY_HOOK=                 # must resolve to the id above
PRODUCTION_API_SERVICE_ID=                 # non-secret production id
FIELD_STAGING_WORKER_MODE=dedicated        # dedicated or in_process
FIELD_STAGING_WORKER_SERVICE_ID=
FIELD_STAGING_WORKER_DEPLOY_HOOK=
PRODUCTION_WORKER_SERVICE_ID=              # non-secret production id

# --- Staging object storage (dedicated bucket; name must contain "staging") --
FIELD_STAGING_OBJECT_STORAGE_BACKEND=r2
FIELD_STAGING_OBJECT_BUCKET=               # e.g. agroai-field-staging
FIELD_STAGING_OBJECT_ACCOUNT_ID=           # non-secret provider account id
PRODUCTION_OBJECT_BUCKET_FINGERPRINT=      # account-id:bucket-name
FIELD_STAGING_OBJECT_ENDPOINT_URL=
FIELD_STAGING_OBJECT_REGION=auto
FIELD_STAGING_OBJECT_PREFIX=staging/field-intelligence
FIELD_STAGING_R2_ACCESS_KEY_ID=            # staging-scoped key, write access to the staging bucket only
FIELD_STAGING_R2_SECRET_ACCESS_KEY=

# --- Staging transcription ----------------------------------------------------
FIELD_STAGING_TRANSCRIPTION_PROVIDER=openai_whisper
FIELD_STAGING_TRANSCRIPTION_ENDPOINT=
FIELD_STAGING_TRANSCRIPTION_API_KEY=       # staging-scoped credential
FIELD_STAGING_TRANSCRIPTION_MODEL=whisper-1

# --- Rollout ------------------------------------------------------------------
FIELD_STAGING_RELEASE_STATE=internal       # general is always refused in staging
FIELD_STAGING_INTERNAL_ORGANIZATION_IDS=   # csv of staging org ids (never in source)

# --- Smoke --------------------------------------------------------------------
FIELD_STAGING_SMOKE_TOKEN=                 # bearer for the internal staging account
FIELD_STAGING_RESTRICTED_SMOKE_TOKEN=      # bearer for a restricted staging account

# --- Cloudflare (staging-scoped token: Pages write on agroai-portal-staging) --
CLOUDFLARE_STAGING_API_TOKEN=
CLOUDFLARE_STAGING_ACCOUNT_ID=

# --- Values the staging API service itself must set (its own env) ------------
# DATABASE_URL=<FIELD_STAGING_DATABASE_URL>
# CONNECTOR_OBJECT_STORAGE_BACKEND=r2
# CONNECTOR_OBJECT_BUCKET=<FIELD_STAGING_OBJECT_BUCKET>
# CONNECTOR_OBJECT_ENDPOINT_URL=<FIELD_STAGING_OBJECT_ENDPOINT_URL>
# CONNECTOR_OBJECT_PREFIX=staging/field-intelligence
# CLOUDFLARE_R2_ACCESS_KEY_ID=<FIELD_STAGING_R2_ACCESS_KEY_ID>
# CLOUDFLARE_R2_SECRET_ACCESS_KEY=<FIELD_STAGING_R2_SECRET_ACCESS_KEY>
# FIELD_TRANSCRIPTION_PROVIDER=<FIELD_STAGING_TRANSCRIPTION_PROVIDER>
# FIELD_TRANSCRIPTION_ENDPOINT=<FIELD_STAGING_TRANSCRIPTION_ENDPOINT>
# FIELD_TRANSCRIPTION_API_KEY=<FIELD_STAGING_TRANSCRIPTION_API_KEY>
# FIELD_INTELLIGENCE_RELEASE_STATE=internal
# FIELD_INTERNAL_ORGANIZATION_IDS=<FIELD_STAGING_INTERNAL_ORGANIZATION_IDS>
# FIELD_INTELLIGENCE_WORKER_ENABLED=true   # or deploy the dedicated worker service
# PLATFORM_ADMIN_EMAILS=<internal staging account email>

# --- Optional API-side release labels -----------------------------------------
# Internal staging verifies the live portal separately in the workflow.
# FIELD_RELEASE_PORTAL_SHA=<exact staged SHA when managed by the provider>
# FIELD_RELEASE_EDGE_SHA=<exact edge SHA when a staging edge exists>
