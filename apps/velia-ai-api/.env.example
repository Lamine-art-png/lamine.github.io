# Terris backend runtime
# Directory and package names intentionally remain velia-ai-api for compatibility.
PORT=4310
CORS_ORIGIN=http://localhost:4174
LOG_LEVEL=info

# Reasoning provider: mock, gemini, openai, anthropic
# Anthropic is a placeholder and falls back locally in this version.
LLM_PROVIDER=mock
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini

# Embeddings provider: mock, gemini, openai
EMBEDDING_PROVIDER=mock
GEMINI_EMBEDDING_MODEL=text-embedding-004
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# Weather provider: mock, openweather
WEATHER_PROVIDER=mock
OPENWEATHER_API_KEY=
WEATHER_CACHE_TTL_MINUTES=45

# Local development persistence
VECTOR_PROVIDER=local
MEMORY_PROVIDER=json
MEMORY_FILE=./src/storage/memory.json
VECTOR_INDEX_FILE=./src/storage/vector-index.json
WEATHER_CACHE_FILE=./src/storage/weather-cache.json

# Terris compatibility aliases. TERRIS_* takes precedence over legacy VELIA_*.
TERRIS_MEMORY_FILE=./src/storage/memory.json
TERRIS_VECTOR_INDEX_FILE=./src/storage/vector-index.json
TERRIS_WEATHER_CACHE_FILE=./src/storage/weather-cache.json

# Terris module gates. Beta modules are false by default until explicitly enabled.
TERRIS_WATER_ENABLED=true
TERRIS_NUTRIENTS_ENABLED=false
TERRIS_ENERGY_ENABLED=false
TERRIS_OPS_ENABLED=false
TERRIS_PROOF_ENABLED=false
TERRIS_PROTECT_ENABLED=false
TERRIS_RISK_API_ENABLED=false

# Provider resilience
PROVIDER_TIMEOUT_MS=12000
PROVIDER_RETRY_COUNT=2
